{
  "name": "proxy-observer",
  "version": "0.3.3",
  "description": "Observable transparent reverse proxy for inspecting real HTTP traffic between agents and upstream APIs.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/NexusAgentX/ProxyObserver",
  "bugs": {
    "url": "https://github.com/NexusAgentX/ProxyObserver/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NexusAgentX/ProxyObserver.git"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "compile": "bun build --compile ./src/index.ts --outfile dist/proxyobserver",
    "typecheck": "tsc --noEmit",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "typescript": "^5"
  }
}
